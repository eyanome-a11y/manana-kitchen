<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Manana Kitchen</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; background: #f6f6f4; color: #1a1a1a; min-height: 100vh; }
#app { max-width: 940px; margin: 0 auto; padding: 1.2rem 1rem 3rem; }
h1 { font-size: 22px; font-weight: 600; margin-bottom: 1px; }
#ml { font-size: 12px; color: #6b6b6b; margin-bottom: 1.2rem; }
.tabs { display: flex; gap: 2px; border-bottom: 1px solid rgba(0,0,0,.12); overflow-x: auto; margin-bottom: 1.3rem; }
.tab { padding: 7px 14px; font-size: 13px; cursor: pointer; border: none; background: transparent; color: #6b6b6b; border-bottom: 2px solid transparent; margin-bottom: -1px; white-space: nowrap; flex-shrink: 0; font-family: inherit; }
.tab.active { color: #1a1a1a; border-bottom-color: #1a1a1a; font-weight: 500; }
.panel { display: none; }
.panel.active { display: block; }
.card { border: 1px solid rgba(0,0,0,.12); border-radius: 10px; overflow: hidden; margin-bottom: .9rem; background: #fff; }
.ch { padding: 8px 14px; background: #f6f6f4; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .06em; color: #6b6b6b; border-bottom: 1px solid rgba(0,0,0,.12); display: flex; justify-content: space-between; align-items: center; }
.dr { border-top: 1px solid rgba(0,0,0,.08); background: #fff; }
.dr:first-child { border-top: none; }
.dh { display: flex; align-items: center; gap: 9px; padding: 10px 14px; cursor: pointer; flex-wrap: wrap; }
.dn { flex: 1; font-size: 14px; font-weight: 500; min-width: 100px; }
.dn.off { color: #aaa; }
.sb { font-size: 11px; padding: 2px 7px; border-radius: 5px; font-weight: 600; white-space: nowrap; }
.tg { display: inline-block; font-size: 10px; padding: 1px 5px; border-radius: 4px; background: #efefec; color: #6b6b6b; border: 1px solid rgba(0,0,0,.1); margin: 1px 2px 1px 0; }
.dd { display: none; padding: 0 14px 14px; border-top: 1px solid rgba(0,0,0,.08); }
.dd.open { display: block; }
.nt { font-size: 12px; color: #6b6b6b; font-style: italic; margin: 10px 0 8px; line-height: 1.6; }
table.it { width: 100%; font-size: 12px; border-collapse: collapse; }
table.it th { color: #aaa; font-weight: 600; padding: 4px 5px 4px 0; text-align: left; font-size: 11px; }
table.it td { padding: 4px 5px 4px 0; border-top: 1px solid rgba(0,0,0,.06); }
table.it td.m { color: #aaa; font-size: 11px; }
.ra { display: flex; gap: 8px; margin-top: 10px; }
.btn { padding: 5px 12px; font-size: 12px; border-radius: 6px; cursor: pointer; border: 1px solid rgba(0,0,0,.2); background: #fff; color: #1a1a1a; font-family: inherit; }
.btn:hover { background: #f6f6f4; }
.btn.d { border-color: #E24B4A; color: #E24B4A; }
.btn.p { font-weight: 600; }
.btn.sm { padding: 3px 9px; font-size: 11px; }
.btn.act { background: #1a1a1a; color: #fff; border-color: #1a1a1a; }
.btn.grn { background: #1D9E75; color: #fff; border-color: #1D9E75; }
.tog { width: 32px; height: 18px; border-radius: 9px; border: 1px solid #ccc; position: relative; cursor: pointer; flex-shrink: 0; transition: background .15s; }
.tog.on { background: #1D9E75; border-color: #1D9E75; }
.tog.off { background: #efefec; }
.tdot { position: absolute; top: 2px; width: 12px; height: 12px; border-radius: 50%; background: white; transition: left .15s; }
.ef { padding: 14px; background: #f6f6f4; border-top: 1px solid rgba(0,0,0,.08); }
.fg { display: flex; flex-direction: column; gap: 2px; margin-bottom: 8px; }
.fg label { font-size: 11px; color: #6b6b6b; font-weight: 500; }
.fg input, .fg select, .fg textarea { width: 100%; font-size: 12px; padding: 5px 8px; border: 1px solid rgba(0,0,0,.2); border-radius: 6px; background: #fff; color: #1a1a1a; font-family: inherit; }
.fg textarea { resize: vertical; }
table.ie { width: 100%; font-size: 11px; border-collapse: collapse; margin-bottom: 8px; }
table.ie th { font-size: 10px; color: #aaa; font-weight: 600; padding: 2px 3px; text-align: left; }
table.ie td { padding: 2px; border-top: 1px solid rgba(0,0,0,.06); }
table.ie input, table.ie select { width: 100%; font-size: 11px; padding: 3px 4px; border: 1px solid rgba(0,0,0,.1); border-radius: 4px; font-family: inherit; }
.xb { background: transparent; border: none; cursor: pointer; color: #E24B4A; font-size: 16px; padding: 0 3px; line-height: 1; }
.evg { display: grid; grid-template-columns: repeat(auto-fit, minmax(85px, 1fr)); gap: 7px; }
.evf label { font-size: 11px; color: #6b6b6b; display: block; margin-bottom: 3px; font-weight: 500; }
.evf input { width: 100%; font-size: 13px; padding: 6px 8px; border: 1px solid rgba(0,0,0,.2); border-radius: 6px; font-weight: 600; font-family: inherit; }
.pr { display: flex; justify-content: space-between; padding: 7px 14px; border-top: 1px solid rgba(0,0,0,.06); font-size: 13px; }
.wi { width: 52px; font-size: 12px; padding: 3px 5px; border: 1px solid rgba(0,0,0,.2); border-radius: 5px; text-align: center; font-family: inherit; }
.abtn { width: 100%; padding: 10px; border: 1px dashed rgba(0,0,0,.2); border-radius: 10px; background: transparent; color: #6b6b6b; cursor: pointer; font-size: 13px; margin-top: 4px; font-family: inherit; }
.ib { padding: 10px 14px; background: #f6f6f4; border: 1px solid rgba(0,0,0,.1); border-radius: 10px; font-size: 12px; color: #6b6b6b; margin-bottom: .9rem; line-height: 1.6; }
.sl-cat { margin-bottom: 1.1rem; }
.sl-lbl { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .07em; color: #6b6b6b; margin-bottom: 4px; display: block; }
.sl-rows { border: 1px solid rgba(0,0,0,.1); border-radius: 10px; overflow: hidden; background: #fff; }
.sl-row { display: flex; align-items: center; gap: 10px; padding: 9px 14px; border-top: 1px solid rgba(0,0,0,.06); font-size: 13px; position: relative; }
.sl-row:first-child { border-top: none; }
.sl-row:nth-child(even) { background: #f9f9f7; }
.sl-row:hover .sl-tt { display: block; }
.sl-tt { display: none; position: absolute; background: #fff; border: 1px solid rgba(0,0,0,.2); border-radius: 8px; padding: 8px 10px; font-size: 11px; color: #6b6b6b; z-index: 10; max-width: 220px; top: 100%; right: 14px; line-height: 1.5; box-shadow: 0 3px 10px rgba(0,0,0,.08); }
.stk-row { display: flex; align-items: center; gap: 10px; padding: 9px 14px; border-top: 1px solid rgba(0,0,0,.06); font-size: 13px; flex-wrap: wrap; }
.stk-row:first-child { border-top: none; }
.exp-ok { background: #EAF3DE; color: #3B6D11; font-size: 11px; padding: 2px 7px; border-radius: 5px; font-weight: 600; }
.exp-warn { background: #FFF3CD; color: #854F0B; font-size: 11px; padding: 2px 7px; border-radius: 5px; font-weight: 600; }
.exp-crit { background: #F8D7DA; color: #A32D2D; font-size: 11px; padding: 2px 7px; border-radius: 5px; font-weight: 600; }
.task-row { display: flex; align-items: flex-start; gap: 8px; padding: 7px 14px; border-top: 1px solid rgba(0,0,0,.06); font-size: 13px; }
.task-row:first-child { border-top: none; }
.task-row input[type=checkbox] { margin-top: 3px; flex-shrink: 0; cursor: pointer; accent-color: #1D9E75; }
.task-row label { flex: 1; line-height: 1.5; cursor: pointer; }
.task-row label.done { text-decoration: line-through; color: #aaa; }
.add-task { display: flex; gap: 6px; padding: 8px 14px; border-top: 1px solid rgba(0,0,0,.06); }
.add-task input { flex: 1; font-size: 12px; padding: 5px 8px; border: 1px solid rgba(0,0,0,.2); border-radius: 6px; font-family: inherit; }
.tmp-form { display: grid; grid-template-columns: 1fr 1fr 2fr auto; gap: 8px; padding: 10px 14px; border-top: 1px solid rgba(0,0,0,.06); align-items: end; }
.tmp-form input { font-size: 13px; padding: 6px 8px; border: 1px solid rgba(0,0,0,.2); border-radius: 6px; font-family: inherit; width: 100%; }
.tmp-form label { font-size: 11px; color: #6b6b6b; font-weight: 500; display: block; margin-bottom: 2px; }
.tmp-row { display: flex; gap: 12px; padding: 7px 14px; border-top: 1px solid rgba(0,0,0,.06); font-size: 12px; align-items: center; flex-wrap: wrap; }
.tmp-row:first-child { border-top: none; }
.allg-tbl { width: 100%; border-collapse: collapse; font-size: 12px; }
.allg-tbl th { padding: 6px 8px; text-align: left; background: #f6f6f4; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .04em; color: #6b6b6b; border: 1px solid rgba(0,0,0,.1); }
.allg-tbl td { padding: 5px 8px; border: 1px solid rgba(0,0,0,.08); }
.allg-dot { display: inline-block; width: 10px; height: 10px; border-radius: 50%; background: #E24B4A; }
.sm-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 8px; margin-bottom: .9rem; }
.sm-card { background: #fff; border: 1px solid rgba(0,0,0,.1); border-radius: 10px; padding: 12px 14px; }
.sm-lbl { font-size: 11px; color: #6b6b6b; font-weight: 500; text-transform: uppercase; letter-spacing: .04em; margin-bottom: 4px; }
.sm-val { font-size: 20px; font-weight: 700; }
.sm-sub { font-size: 11px; color: #aaa; margin-top: 2px; }
.xrow { display: flex; align-items: center; gap: 8px; padding: 8px 14px; border-top: 1px solid rgba(0,0,0,.06); font-size: 13px; flex-wrap: wrap; }
.xrow:first-child { border-top: none; }
.xrow:nth-child(even) { background: #f9f9f7; }
.fbar { display: flex; gap: 8px; margin-bottom: .9rem; flex-wrap: wrap; align-items: center; }
.fbar input, .fbar select { font-size: 12px; padding: 5px 8px; border: 1px solid rgba(0,0,0,.2); border-radius: 6px; font-family: inherit; background: #fff; }
.week-badge { font-size: 12px; padding: 4px 10px; border: 1px solid rgba(0,0,0,.1); border-radius: 6px; color: #6b6b6b; background: #fff; }
</style>
</head>
<body>
<div id="app">
  <div style="margin-bottom:1.2rem;display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:8px">
    <div><h1>Manana</h1><p id="ml">Kitchen · Walton-on-Thames</p></div>
    <span class="week-badge" id="wb"></span>
  </div>
  <div class="tabs">
    <button class="tab active" onclick="ST('dishes')">Dishes</button>
    <button class="tab" onclick="ST('stock')">Stock</button>
    <button class="tab" onclick="ST('tasks')">Tasks</button>
    <button class="tab" onclick="ST('expenses')">Expenses</button>
    <button class="tab" onclick="ST('shopping')">Shopping</button>
    <button class="tab" onclick="ST('temps')">Temp log</button>
    <button class="tab" onclick="ST('allergens')">Allergens</button>
    <button class="tab" onclick="ST('events')">Events</button>
  </div>
  <div id="pd-dishes" class="panel active"></div>
  <div id="pd-stock" class="panel"></div>
  <div id="pd-tasks" class="panel"></div>
  <div id="pd-expenses" class="panel"></div>
  <div id="pd-shopping" class="panel"></div>
  <div id="pd-temps" class="panel"></div>
  <div id="pd-allergens" class="panel"></div>
  <div id="pd-events" class="panel"></div>
</div>
<script src="/app.js"></script>
</body>
</html>
